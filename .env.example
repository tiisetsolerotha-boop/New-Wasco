# =============================================
# WASCO - Environment Variables Template
# Copy this to .env and fill in your values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ---- DB1: PostgreSQL (Supabase) ----
# Main DB: Customers, BillingRates, Bills, LeakageReports
PG_HOST=db.your-project.supabase.co
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=your_supabase_password
PG_SSL=true

# ---- DB2: MySQL (Railway) ----
# Fragment DB: WaterUsage, Payments
MYSQL_HOST=your-railway-host.railway.app
MYSQL_PORT=3306
MYSQL_DATABASE=railway
MYSQL_USER=root
MYSQL_PASSWORD=your_railway_password

# ---- Frontend ----
FRONTEND_URL=http://localhost:5173
